# LLM provider: anthropic | openai
LLM_PROVIDER=anthropic
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
LLM_MODEL=claude-sonnet-4-6

# Data paths (local dev)
DATA_DIR=./data
DUCKDB_PATH=./data/navigator.duckdb
CHROMA_PATH=./data/chroma

# Production (Render / Docker) — set in render.yaml or dashboard
# DATA_DIR=/data
# DUCKDB_PATH=/data/navigator.duckdb
# CHROMA_PATH=/data/chroma

# API
API_HOST=0.0.0.0
API_PORT=8000
# Render injects PORT automatically
CORS_ORIGINS=http://localhost:5173,http://localhost:8000
# Production: CORS_ORIGINS=https://your-app.onrender.com

# Session
SESSION_TTL_MINUTES=30
MAX_CHAT_TURNS=5

# Navigator: mcp_agent | legacy_pipeline
NAVIGATOR_MODE=mcp_agent
MAX_TOOL_ROUNDS=8

# LLM reliability (production)
LLM_TIMEOUT_SECONDS=60
LLM_MAX_RETRIES=2

# Offline tests / local dev without API keys — do not set on production Render
# LLM_MOCK=1

# Nightly ingest schedule is in config/deploy.yaml (UTC cron for supercronic)

# Render MCP (local Cursor only — do not set on the Render service)
RENDER_API_KEY=
